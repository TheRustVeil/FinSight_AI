# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finsight"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT (generate with: openssl rand -base64 48) ────────────────────────────
JWT_ACCESS_SECRET="change_me_to_a_random_32_char_min_secret_key_here"
JWT_REFRESH_SECRET="change_me_to_another_random_32_char_min_secret_key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Email (MailHog in dev: host=localhost, port=1025) ────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="FinSight AI <noreply@finsight.ai>"

# ─── AWS / MinIO (local dev: endpoint=http://localhost:9000) ──────────────────
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_S3_BUCKET="finsight-uploads"
AWS_S3_ENDPOINT="http://localhost:9000"

# ─── AI (Google Gemini — get a free key at aistudio.google.com/apikey) ────────
GEMINI_API_KEY="AIza..."

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
BCRYPT_ROUNDS="12"
# Set to "true" to auto-verify new accounts without sending email (demo deploy
# with no SMTP provider). Dev already auto-verifies regardless.
AUTH_AUTO_VERIFY="false"
