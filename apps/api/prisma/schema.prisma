generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

enum UserPlan {
  free
  pro
  business
}

enum AccountType {
  checking
  savings
  credit
  cash
  investment
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransactionSource {
  manual
  csv
  pdf
  ocr
  api
}

enum BudgetPeriod {
  weekly
  monthly
  yearly
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

enum InsightType {
  spending_spike
  subscription_detected
  savings_opportunity
  anomaly
  forecast
  comparison
  recommendation
}

enum InsightSeverity {
  info
  warning
  alert
}

enum NotificationChannel {
  in_app
  email
  push
}

enum AIMessageRole {
  user
  assistant
  system
}

enum Theme {
  light
  dark
  system
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  emailVerified Boolean   @default(false) @map("email_verified")
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  fullName      String    @map("full_name") @db.VarChar(255)
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(user)
  plan          UserPlan  @default(free)
  currency      String    @default("INR") @db.VarChar(3)
  timezone      String    @default("Asia/Kolkata") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  oauthAccounts      OAuthAccount[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  accounts           Account[]
  transactions       Transaction[]
  categories         Category[]
  budgets            Budget[]
  goals              Goal[]
  importBatches      ImportBatch[]
  aiConversations    AIConversation[]
  insights           Insight[]
  notifications      Notification[]
  preferences        UserPreference?
  auditLogs          AuditLog[]

  @@map("users")
}

model OAuthAccount {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  provider     String    @db.VarChar(50)
  providerId   String    @map("provider_id") @db.VarChar(255)
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo Json?     @map("device_info")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Account {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  name        String      @db.VarChar(255)
  type        AccountType
  institution String?     @db.VarChar(255)
  currency    String      @default("INR") @db.VarChar(3)
  balance     Decimal     @default(0) @db.Decimal(15, 2)
  isDefault   Boolean     @default(false) @map("is_default")
  color       String?     @db.VarChar(7)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  importBatches ImportBatch[]

  @@map("accounts")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  color     String?  @db.VarChar(7)
  parentId  String?  @map("parent_id") @db.Uuid
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Category?        @relation("CategoryChildren", fields: [parentId], references: [id])
  children         Category[]       @relation("CategoryChildren")
  transactions     Transaction[]    @relation("TransactionCategory")
  aiTransactions   Transaction[]    @relation("TransactionAICategory")
  budgetCategories BudgetCategory[]

  @@map("categories")
}

model Transaction {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  accountId  String?           @map("account_id") @db.Uuid
  categoryId String?           @map("category_id") @db.Uuid

  amount   Decimal         @db.Decimal(15, 2)
  currency String          @default("INR") @db.VarChar(3)
  type     TransactionType

  merchant    String? @db.VarChar(255)
  description String?
  notes       String?

  date      DateTime  @db.Date
  valueDate DateTime? @map("value_date") @db.Date

  aiCategoryId        String?  @map("ai_category_id") @db.Uuid
  aiConfidence        Decimal? @map("ai_confidence") @db.Decimal(4, 3)
  aiCategoryConfirmed Boolean  @default(false) @map("ai_category_confirmed")
  aiLabels            String[] @map("ai_labels")

  source        TransactionSource @default(manual)
  importBatchId String?           @map("import_batch_id") @db.Uuid
  externalId    String?           @map("external_id") @db.VarChar(255)
  rawText       String?           @map("raw_text")

  isRecurring Boolean  @default(false) @map("is_recurring")
  isInternal  Boolean  @default(false) @map("is_internal")
  isFlagged   Boolean  @default(false) @map("is_flagged")
  flagReason  String?  @map("flag_reason") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account    Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category   Category?    @relation("TransactionCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  aiCategory Category?    @relation("TransactionAICategory", fields: [aiCategoryId], references: [id], onDelete: SetNull)
  tags       TransactionTag[]
  attachments Attachment[]

  @@unique([userId, externalId])
  @@index([userId, date(sort: Desc)])
  @@index([userId, categoryId])
  @@index([userId, type])
  @@index([importBatchId])
  @@map("transactions")
}

model TransactionTag {
  transactionId String @map("transaction_id") @db.Uuid
  tag           String @db.VarChar(50)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@id([transactionId, tag])
  @@map("transaction_tags")
}

model Attachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  transactionId String?  @map("transaction_id") @db.Uuid
  fileKey       String   @map("file_key")
  fileName      String?  @map("file_name") @db.VarChar(255)
  mimeType      String?  @map("mime_type") @db.VarChar(100)
  fileSize      Int?     @map("file_size")
  ocrJobId      String?  @map("ocr_job_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("attachments")
}

model Budget {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  name        String       @db.VarChar(255)
  period      BudgetPeriod @default(monthly)
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  totalAmount Decimal?     @map("total_amount") @db.Decimal(15, 2)
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetCategories BudgetCategory[]
  budgetAlerts     BudgetAlert[]

  @@map("budgets")
}

model BudgetCategory {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId        String  @map("budget_id") @db.Uuid
  categoryId      String  @map("category_id") @db.Uuid
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(15, 2)
  alertAtPercent  Int     @default(80) @map("alert_at_percent")

  budget       Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  budgetAlerts BudgetAlert[]

  @@unique([budgetId, categoryId])
  @@map("budget_categories")
}

model BudgetAlert {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId         String   @map("budget_id") @db.Uuid
  budgetCategoryId String   @map("budget_category_id") @db.Uuid
  triggeredAt      Decimal  @map("triggered_at") @db.Decimal(5, 2)
  firedAt          DateTime @default(now()) @map("fired_at") @db.Timestamptz
  notified         Boolean  @default(false)

  budget         Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  budgetCategory BudgetCategory @relation(fields: [budgetCategoryId], references: [id], onDelete: Cascade)

  @@map("budget_alerts")
}

model Goal {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String    @db.VarChar(255)
  targetAmount  Decimal   @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(15, 2)
  targetDate    DateTime? @map("target_date") @db.Date
  category      String?   @db.VarChar(100)
  isCompleted   Boolean   @default(false) @map("is_completed")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@map("goals")
}

model GoalContribution {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId        String   @map("goal_id") @db.Uuid
  amount        Decimal  @db.Decimal(15, 2)
  notes         String?
  contributedAt DateTime @default(now()) @map("contributed_at") @db.Timestamptz

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_contributions")
}

model ImportBatch {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  accountId    String?      @map("account_id") @db.Uuid
  sourceType   String       @map("source_type") @db.VarChar(20)
  fileKey      String       @map("file_key")
  fileName     String?      @map("file_name") @db.VarChar(255)
  status       ImportStatus @default(pending)
  totalRows    Int?         @map("total_rows")
  importedRows Int          @default(0) @map("imported_rows")
  errorMessage String?      @map("error_message")
  metadata     Json?
  startedAt    DateTime?    @map("started_at") @db.Timestamptz
  completedAt  DateTime?    @map("completed_at") @db.Timestamptz
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id])

  @@map("import_batches")
}

model AIConversation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  title           String?  @db.VarChar(255)
  contextSnapshot Json?    @map("context_snapshot")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@map("ai_conversations")
}

model AIMessage {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  role           AIMessageRole
  content        String
  tokensUsed     Int?          @map("tokens_used")
  model          String?       @db.VarChar(100)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model Insight {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        InsightType
  title       String          @db.VarChar(255)
  body        String
  data        Json?
  severity    InsightSeverity @default(info)
  periodStart DateTime?       @map("period_start") @db.Date
  periodEnd   DateTime?       @map("period_end") @db.Date
  isRead      Boolean         @default(false) @map("is_read")
  isDismissed Boolean         @default(false) @map("is_dismissed")
  expiresAt   DateTime?       @map("expires_at") @db.Timestamptz
  generatedAt DateTime        @default(now()) @map("generated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isDismissed])
  @@map("insights")
}

model Notification {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      String              @db.VarChar(50)
  title     String              @db.VarChar(255)
  body      String?
  data      Json?
  channel   NotificationChannel @default(in_app)
  isRead    Boolean             @default(false) @map("is_read")
  sentAt    DateTime?           @map("sent_at") @db.Timestamptz
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model UserPreference {
  userId               String   @id @map("user_id") @db.Uuid
  notificationEmail    Boolean  @default(true) @map("notification_email")
  notificationInApp    Boolean  @default(true) @map("notification_in_app")
  budgetAlertThreshold Int      @default(80) @map("budget_alert_threshold")
  aiAutoCategorize     Boolean  @default(true) @map("ai_auto_categorize")
  dashboardWidgets     Json?    @map("dashboard_widgets")
  theme                Theme    @default(system)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(100)
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.Uuid
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_logs")
}
