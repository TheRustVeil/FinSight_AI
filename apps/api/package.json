{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "prisma generate",
    "start": "tsx src/server.ts",
    "postinstall": "prisma generate",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
