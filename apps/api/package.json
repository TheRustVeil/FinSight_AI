    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
