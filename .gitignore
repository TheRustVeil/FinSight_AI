!.yarn/patches
!.yarn/releases
.pnp.*

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ── Env / secrets (keep the *.example templates) ──────────────
.env
.env.*
!.env.example
!.env.*.example

# ── Prisma local artifacts ────────────────────────────────────
prisma/migrations/dev.db
*.db
*.sqlite

# ── Deploy / platform ─────────────────────────────────────────
.vercel/
.netlify/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── Test / coverage ───────────────────────────────────────────
coverage/

# ── Editor / OS ───────────────────────────────────────────────
.vscode/*
